# =============================================
# CHEGOU AÍ — VARIÁVEIS DE AMBIENTE
# =============================================
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git!

# Servidor
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# =============================================
# SUPABASE
# =============================================
# Obtenha em: https://app.supabase.com → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# =============================================
# ASAAS — Gateway de Pagamento
# =============================================
# Crie conta em: https://www.asaas.com
# Sandbox: https://sandbox.asaas.com
# API Key em: Configurações → Integrações → API Key
ASAAS_API_KEY=$aact_sua-api-key-aqui

# Token para validar webhooks (defina em: Asaas → Configurações → Notificações → Token)
ASAAS_WEBHOOK_TOKEN=seu-webhook-token-aqui

# Taxas do gateway (ajuste conforme seu plano Asaas)
ASAAS_TAXA_PIX=0.99       # R$ fixo por transação Pix
ASAAS_TAXA_CARTAO=2.99    # % sobre o total para cartão de crédito

# =============================================
# FIREBASE — GPS em Tempo Real
# =============================================
# Crie projeto em: https://console.firebase.google.com
# Ative Realtime Database (modo "test" inicial, depois ajuste regras)
# Obtenha config em: Configurações do projeto → Seus apps → Web → SDK
FIREBASE_API_KEY=AIza-sua-api-key-aqui
FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
FIREBASE_DATABASE_URL=https://seu-projeto-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=seu-projeto
FIREBASE_APP_ID=1:123456789:web:abc123

# =============================================
# JWT (para sessões extras se necessário)
# =============================================
JWT_SECRET=gere-uma-string-aleatoria-segura-de-64-chars-aqui

# =============================================
# WEBHOOK
# =============================================
# URL pública do servidor para receber notificações do Asaas
# Em desenvolvimento use ngrok: ngrok http 3000
WEBHOOK_URL=https://seu-dominio.com.br
