# =============================================
# CHEGOU AÍ — VARIÁVEIS DE AMBIENTE
# =============================================
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git!

# Servidor
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# =============================================
# SUPABASE
# =============================================
# Obtenha em: https://app.supabase.com → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# =============================================
# MERCADO PAGO
# =============================================
# Obtenha em: https://www.mercadopago.com.br/developers
# Use credenciais TEST-* para testes, sem prefixo para produção
MP_ACCESS_TOKEN=TEST-seu-access-token-aqui
MP_PUBLIC_KEY=TEST-sua-public-key-aqui

# ID da sua conta Mercado Pago (para receber comissões)
# Encontre em: https://www.mercadopago.com.br/developers/panel/app
MP_PLATAFORMA_USER_ID=seu-user-id-mp

# =============================================
# JWT (para sessões extras se necessário)
# =============================================
JWT_SECRET=gere-uma-string-aleatoria-segura-de-64-chars-aqui

# =============================================
# WEBHOOK
# =============================================
# URL pública do servidor para receber notificações do MP
# Em desenvolvimento use ngrok: ngrok http 3000
WEBHOOK_URL=https://seu-dominio.com.br
