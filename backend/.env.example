# =============================================
# CHEGOU AÍ — VARIÁVEIS DE AMBIENTE
# =============================================
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git!

# Servidor
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# =============================================
# SUPABASE
# =============================================
# Obtenha em: https://app.supabase.com → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# =============================================
# PAGAR.ME — Gateway de Pagamento
# =============================================
# Crie conta em: https://dashboard.pagar.me
# API Key em: Dashboard → Configurações → API Keys
# Use a chave secreta (sk_...) — nunca a chave pública
PAGARME_API_KEY=sk_sua-api-key-aqui

# Secret para validar assinaturas de webhook (configure em: Dashboard → Webhooks)
PAGARME_WEBHOOK_SECRET=seu-webhook-secret-aqui

# Recipient ID da conta da plataforma no Pagar.me (recebe o remainder do split e envia Pix ao motoboy)
PAGARME_RECIPIENT_ID_PLATAFORMA=re_seu-recipient-id-plataforma-aqui

# Taxas Pagar.me — ajuste conforme seu plano (os defaults abaixo são estimativas)
# Taxa percentual do Pix (% sobre o total)
PAGARME_TAXA_PIX_PERCENT=0.99
# Taxa base do cartão de crédito (%)
PAGARME_TAXA_CARTAO_PERCENT=3.99
# Taxa de antecipação D+0 (%) — requer aprovação Pagar.me
PAGARME_TAXA_ANTECIPACAO_PERCENT=1.99
# Taxa fixa por transação de cartão (R$)
PAGARME_TAXA_FIXA_CARTAO=0.70

# =============================================
# JWT (para sessões extras se necessário)
# =============================================
JWT_SECRET=gere-uma-string-aleatoria-segura-de-64-chars-aqui

# =============================================
# WEBHOOK
# =============================================
# URL pública do servidor para receber notificações do Pagar.me
# Em desenvolvimento use ngrok: ngrok http 3000
WEBHOOK_URL=https://seu-dominio.com.br
